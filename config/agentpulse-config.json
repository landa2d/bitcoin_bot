{
  "version": "1.1.0",
  "models": {
    "extraction": "deepseek-chat",
    "clustering": "deepseek-chat",
    "trending_topics": "deepseek-chat",
    "opportunity_generation": "deepseek-chat",
    "digest": "deepseek-chat",
    "personal_briefing": "deepseek-chat",
    "default": "deepseek-chat"
  },
  "budgets": {
    "analyst": {
      "full_analysis": {
        "max_llm_calls": 8,
        "max_seconds": 300,
        "max_subtasks": 3,
        "max_retries": 2
      },
      "deep_dive": {
        "max_llm_calls": 5,
        "max_seconds": 180,
        "max_subtasks": 2,
        "max_retries": 1
      },
      "review_opportunity": {
        "max_llm_calls": 3,
        "max_seconds": 120,
        "max_subtasks": 1,
        "max_retries": 1
      },
      "proactive_scan": {
        "max_llm_calls": 4,
        "max_seconds": 120,
        "max_subtasks": 1,
        "max_retries": 1
      }
    },
    "newsletter": {
      "write_newsletter": {
        "max_llm_calls": 6,
        "max_seconds": 300,
        "max_subtasks": 2,
        "max_retries": 2
      },
      "revise_newsletter": {
        "max_llm_calls": 3,
        "max_seconds": 120,
        "max_subtasks": 1,
        "max_retries": 1
      }
    },
    "global": {
      "max_subtask_depth": 2,
      "max_daily_llm_calls": 100,
      "max_daily_proactive_alerts": 5,
      "cooldown_between_proactive_scans_minutes": 60
    }
  },
  "pipelines": {
    "scrape": {
      "enabled": true,
      "interval_hours": 6,
      "submolts": ["bitcoin", "agents", "ai", "tech", "general"],
      "posts_per_submolt": 50,
      "include_comments": true
    },
    "opportunity_finder": {
      "enabled": true,
      "interval_hours": 12,
      "min_problem_frequency": 1,
      "cluster_similarity_threshold": 0.75,
      "top_opportunities_count": 5
    }
  },
  "notifications": {
    "telegram": {
      "on_new_opportunity": true,
      "daily_digest": true,
      "digest_hour": 9
    }
  },
  "negotiation": {
    "max_rounds_per_negotiation": 2,
    "max_active_negotiations_per_agent": 3,
    "negotiation_timeout_minutes": 30,
    "allowed_pairs": {
      "newsletter_can_ask": ["analyst", "processor"],
      "analyst_can_ask": ["processor"],
      "gato_can_ask": ["analyst", "processor", "newsletter"],
      "processor_can_ask": []
    }
  },
  "spotlight_selection": {
    "min_score_threshold": 0.15,
    "cooldown_issues": 2,
    "min_mentions": 1,
    "min_source_tiers": 1,
    "max_queue_items": 1
  },
  "analysis": {
    "model": "gpt-4o",
    "max_tokens": 4000,
    "temperature": 0.3
  },
  "pricing": {
    "gpt-4o": {"input": 2.50, "output": 10.00, "provider": "openai"},
    "gpt-4o-mini": {"input": 0.15, "output": 0.60, "provider": "openai"},
    "deepseek-chat": {"input": 0.27, "output": 1.10, "provider": "deepseek"},
    "deepseek-reasoner": {"input": 0.55, "output": 2.19, "provider": "deepseek"},
    "claude-sonnet-4-20250514": {"input": 3.00, "output": 15.00, "provider": "anthropic"}
  },
  "block_pipeline": {
    "enabled": false,
    "ab_comparison": false,
    "model_prepass": "claude-sonnet-4-20250514",
    "model_structure": "claude-sonnet-4-20250514",
    "model_prose": "claude-sonnet-4-20250514",
    "model_voice": "deepseek-chat"
  },
  "wallet_pricing": {
    "deepseek-chat": 2,
    "deepseek-reasoner": 5,
    "gpt-4o-mini": 5,
    "gpt-4o": 50,
    "claude-sonnet-4-20250514": 80,
    "default": 10
  }
}
